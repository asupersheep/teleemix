# ── Telegram ────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ── Deemix ──────────────────────────────────────────────────────────────────
# URL where your deemix instance is reachable from this container.
DEEMIX_URL=http://localhost:6595

# Your Deezer ARL token (long-lived session cookie from deezer.com).
# How to get it:
#   1. Log in to deezer.com in your browser
#   2. Open DevTools (F12) → Network tab → refresh the page
#   3. Click any request to deezer.com → Request Headers → find the Cookie header
#   4. Copy the value after "arl=" up to the next ";"
# The token is ~190 characters and lasts several months.
# When it expires, use the /updatearl command in Telegram to update it.
DEEMIX_ARL=your_deezer_arl_here

# ── Access Control ───────────────────────────────────────────────────────────
# Comma-separated list of Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone (not recommended for public deployments).
# To find your Telegram user ID, message @userinfobot on Telegram.
ALLOWED_USERS=

# ── Compose / Docker (for /updatearl auto-rebuild) ──────────────────────────
# Path to your docker-compose file INSIDE the container (do not change this).
# Update the HOST side of the volume mount in docker-compose.yml instead.
COMPOSE_FILE=/compose/docker-compose.yml
# Name of this service in your docker-compose file.
SERVICE_NAME=teleemix
# Path to your .env file INSIDE the container (do not change this).
# The /updatearl command writes the new ARL here so it persists across restarts.
ENV_FILE=/app/.env

# ── Timezone ─────────────────────────────────────────────────────────────────
TZ=Your/Timezone  # e.g. Europe/Amsterdam, America/New_York, Asia/Tokyo

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info
