# ── Telegram ────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ── Deemix ──────────────────────────────────────────────────────────────────
# URL where your deemix instance is reachable from this container.
DEEMIX_URL=http://localhost:6595

# Your Deezer ARL token. See README for how to obtain it.
# Use /updatearl in Telegram to update it when it expires.
DEEMIX_ARL=your_deezer_arl_here

# ── Song Recognition (optional) ──────────────────────────────────────────────
# AudD API key for identifying songs from voice recordings.
# Free tier: 100 recognitions/month. Sign up at https://audd.io/
# Leave empty to disable.
AUDD_API_KEY=

# ── Voice Search / Whisper (optional — choose ONE of the three options) ──────

# Option 1: OpenAI remote Whisper API (easiest, pay-per-use ~$0.006/min)
# Sign up at https://platform.openai.com/ — leave empty if using option 2 or 3.
OPENAI_API_KEY=

# Option 2: Point to your own OpenAI-compatible Whisper server
# e.g. a faster-whisper-server running elsewhere on your network.
# Leave empty if using option 1 or 3.
WHISPER_URL=

# Option 3: Use the built-in local Whisper service from docker-compose.yml
# Set to true AND uncomment the whisper service in docker-compose.yml.
# Leave as false if using option 1 or 2.
WHISPER_LOCAL=false

# ── Compose / Docker ─────────────────────────────────────────────────────────
COMPOSE_FILE=/compose/docker-compose.yml
SERVICE_NAME=teleemix
ENV_FILE=/app/.env
USERS_FILE=/app/users.json

# ── Timezone ─────────────────────────────────────────────────────────────────
TZ=Your/Timezone  # e.g. Europe/Amsterdam, America/New_York, Asia/Tokyo

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info
