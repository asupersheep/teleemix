# ── Telegram ────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ── Deemix ──────────────────────────────────────────────────────────────────
# URL where your deemix instance is reachable from this container.
DEEMIX_URL=http://localhost:6595

# Your Deezer ARL token. See README for how to obtain it.
# Use /updatearl in Telegram to update it when it expires.
DEEMIX_ARL=your_deezer_arl_here

# ── Access Control ───────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone. Find your ID via @userinfobot on Telegram.
ALLOWED_USERS=

# ── Voice Features (optional) ────────────────────────────────────────────────
# Leave empty to disable. Users can toggle these per-user in /settings.

# AudD API key for song recognition (identify a song from a recording).
# Free tier: 100 recognitions/month. Sign up at https://audd.io/
AUDD_API_KEY=

# OpenAI API key for voice search (transcribe spoken song/artist names).
# Pay-per-use, fractions of a cent per request. Sign up at https://platform.openai.com/
OPENAI_API_KEY=

# ── Compose / Docker ─────────────────────────────────────────────────────────
# Path to your docker-compose file INSIDE the container (do not change).
COMPOSE_FILE=/compose/docker-compose.yml
# Name of this service in your docker-compose file.
SERVICE_NAME=teleemix
# Path to your .env file INSIDE the container (do not change).
ENV_FILE=/app/.env
# Path to the users database INSIDE the container (do not change).
USERS_FILE=/app/users.json

# ── Timezone ─────────────────────────────────────────────────────────────────
TZ=Your/Timezone  # e.g. Europe/Amsterdam, America/New_York, Asia/Tokyo

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info
